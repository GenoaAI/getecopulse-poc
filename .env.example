# ── Required ──────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
MAPBOX_API_KEY=pk.your_mapbox_access_token_here

# ── Optional — Supabase (persistence + satellite image storage) ────────────────
# Leave blank to run in stateless mode (audits not saved)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ── Optional — Stripe (payment tunnel) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_CENTS=2900

# ── Optional — CORS (backend, comma-separated origins) ────────────────────────
# Defaults to localhost:3000,localhost:3001 for local dev.
# Set to your Vercel frontend URL in production.
ALLOWED_ORIGINS=https://your-project.vercel.app
